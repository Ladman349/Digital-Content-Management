# Environment Configuration (development, production)
APP_ENV=development

# Database Connection (local PostgreSQL or Supabase PostgreSQL Connection String)
DATABASE_URL=postgresql://postgres:121@localhost:5432/postgres

# Supabase Storage Configurations (leave empty to fallback to local uploads storage)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=media

# Public API endpoints and CORS configuration
API_BASE_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Application Secrets (Must be changed in production mode)
SECRET_KEY=super-secret-key-change-in-production
